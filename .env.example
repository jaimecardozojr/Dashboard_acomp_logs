# ============================================================
# Variáveis de ambiente do ROBÔ (rode: copie para .env e preencha)
# O dashboard online usa .streamlit/secrets.toml, não este arquivo.
# ============================================================

# Caminho para o JSON da conta de serviço do Google Cloud.
# Crie em: console.cloud.google.com -> IAM -> Contas de serviço -> Chaves.
# Depois compartilhe a planilha do Google Sheets com o e-mail da conta.
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# (Opcional) sobrescreve o backend definido no config.yaml: gsheets | local
# STORAGE_BACKEND=gsheets
