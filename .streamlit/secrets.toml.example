# Copie para .streamlit/secrets.toml e preencha.
# No Streamlit Community Cloud, cole este conteúdo em "Settings -> Secrets".

# Backend de dados do dashboard online
storage_backend = "gsheets"
spreadsheet = "Acompanhamento Automacoes"   # nome OU ID da planilha
worksheet = "execucoes"

# Link da tarefa no Gestta (mantém o ID do dashboard fora do repositório).
# Troque SEU_DASHBOARD_ID pelo da sua conta.
gestta_task_url = "https://app.gestta.com.br/#/sidebar/task/overview/dashboard/SEU_DASHBOARD_ID?type=SERVICE_ORDER&type=RECURRENT&type=ACCOUNTING&start_date={start}&end_date={end}&status=OPEN&status=IMPEDIMENT&date_type=COMPETENCE_DATE&no_owner=0&os_free=0&os_workflow=1&searchText={search}"

# Conta de serviço do Google (copie do seu service_account.json)
[gcp_service_account]
type = "service_account"
project_id = "seu-projeto"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "robo-logs@seu-projeto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
